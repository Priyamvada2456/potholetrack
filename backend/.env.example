# Copy this file to .env and fill in real values. Never commit the real .env.

# PostgreSQL connection string
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/potholetrack

# Any long random string - used to sign JWT admin session tokens
JWT_SECRET_KEY=change-this-to-a-long-random-string

# Flask secret key (sessions, CSRF, etc.)
SECRET_KEY=change-this-too

# Folder where uploaded photos are stored (relative to backend/app)
UPLOAD_FOLDER=uploads

# Max upload size in MB
MAX_UPLOAD_MB=8

# Radius (in meters) used for duplicate pothole detection
DUPLICATE_RADIUS_METERS=20
